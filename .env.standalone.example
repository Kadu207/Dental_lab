# Copie para .env na raiz ao usar docker-compose.standalone.yml
# docker compose -f docker-compose.standalone.yml --env-file .env up -d --build

LAB_POSTGRES_DB=dental_lab
LAB_POSTGRES_USER=dental_lab
LAB_POSTGRES_PASSWORD=troque-esta-senha
LAB_POSTGRES_PORT=5433

LAB_WEB_PORT=9180

DENTAL_LAB_JWT_SECRET=troque-jwt-secreto-longo
DENTAL_LAB_LICENSE_REQUIRED=false
DENTAL_LAB_LICENSE_KEY=
# URL do Gerador de Licenças (host.docker.internal se o gerador roda no host Windows)
# Dev local com Gerador no host (Windows Docker Desktop):
# DENTAL_LAB_LICENSE_SERVER_URL=http://host.docker.internal:8195
# DENTAL_LAB_LICENSE_SERVER_API_KEY=sua-product-api-key
# DENTAL_LAB_TRIAL_DAYS=30
DENTAL_LAB_CORS_ORIGINS=http://localhost:9180
