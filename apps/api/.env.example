PORT=3333

# standalone | embedded
DENTAL_LAB_DEPLOYMENT_MODE=standalone

# sqlite (dev) | postgres (produção / integrado)
DENTAL_LAB_DB_DRIVER=sqlite

# Postgres standalone: postgresql://user:pass@localhost:5433/dental_lab
# Postgres embedded: mesmo banco do ERP (schema dental_lab)
# DENTAL_LAB_DATABASE_URL=postgresql://dental_lab:dental_lab@localhost:5433/dental_lab

# Embedded: URL do Postgres do Excellence (tabela usuario). Se vazio, usa DATABASE_URL.
# DENTAL_LAB_ERP_DATABASE_URL=postgresql://excellence:excellence@localhost:5432/excellence

# Mesmo SECRET_KEY do Excellence (embedded)
# DENTAL_LAB_ERP_JWT_SECRET=

DENTAL_LAB_POSTGRES_SCHEMA=dental_lab

DENTAL_LAB_CORS_ORIGINS=http://localhost:5173

DENTAL_LAB_LICENSE_REQUIRED=false
DENTAL_LAB_LICENSE_KEY=

# Servidor remoto de licenças (Gerador de Licenças)
# Dev local: http://127.0.0.1:8195
# DENTAL_LAB_LICENSE_SERVER_URL=http://127.0.0.1:8195
# Produção: https://licencas.inovatitech.com.br
# DENTAL_LAB_LICENSE_SERVER_API_KEY=mesma-chave-do-PRODUCT_API_KEY-do-gerador
# DENTAL_LAB_TRIAL_DAYS=30

DENTAL_LAB_AUTH_REQUIRED=true

# PRODUÇÃO (obrigatório alterar):
# DENTAL_LAB_JWT_SECRET=<secret-forte-64-chars>
# DENTAL_LAB_DATABASE_URL=postgresql://user:pass@host:5432/dental_lab
# DENTAL_LAB_CORS_ORIGINS=https://seu-dominio.com
# Altere senha do admin após primeiro login (admin/admin123)

DENTAL_LAB_JWT_SECRET=dev-lab-jwt-change-in-production
DENTAL_LAB_JWT_TTL_MINUTES=480

# DENTAL_LAB_SQLITE_PATH=
