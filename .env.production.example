# Copie para .env na VPS: /opt/dental-lab-system/.env
# Domínio: https://dentallab.inovatitech.com.br

LAB_POSTGRES_DB=dental_lab
LAB_POSTGRES_USER=dental_lab
LAB_POSTGRES_PASSWORD=TROQUE-SENHA-POSTGRES-FORTE

# Bind local — nginx da VPS faz proxy HTTPS
LAB_WEB_PORT=9180

DENTAL_LAB_JWT_SECRET=GERE-JWT-SECRET-MIN-64-CHARS
DENTAL_LAB_CORS_ORIGINS=https://dentallab.inovatitech.com.br

# Licenciamento remoto (Gerador de Licenças)
DENTAL_LAB_LICENSE_REQUIRED=true
DENTAL_LAB_LICENSE_KEY=
DENTAL_LAB_LICENSE_SERVER_URL=https://licencas.inovatitech.com.br
DENTAL_LAB_LICENSE_SERVER_API_KEY=MESMA-PRODUCT_API_KEY-DO-GERADOR
DENTAL_LAB_TRIAL_DAYS=30

# Login — recuperação de senha por e-mail
DENTAL_LAB_APP_URL=https://dentallab.inovatitech.com.br
DENTAL_LAB_SMTP_ENABLED=true
DENTAL_LAB_SMTP_HOST=smtp.seudominio.com
DENTAL_LAB_SMTP_PORT=587
DENTAL_LAB_SMTP_SECURE=false
DENTAL_LAB_SMTP_USER=
DENTAL_LAB_SMTP_PASS=
DENTAL_LAB_SMTP_FROM=Dental Lab <noreply@dentallab.inovatitech.com.br>
DENTAL_LAB_PASSWORD_RESET_EXPOSE_TOKEN=false
